# Copy to .env and fill in what you need. Everything is optional —
# panels fall back to sample data until their integration is configured.

# Port the backend listens on (Vite dev proxy expects 8787).
PORT=8787

# Your timezone, used for "today"/day offsets in calendar and email times.
TZ=Asia/Seoul

# Public URL of the deployed dashboard, used to build the OAuth redirect URI
# behind proxies/hosting platforms. Leave unset for local development.
# PUBLIC_URL=https://dashboard.example.com

# Frontend origins allowed to call this backend cross-origin (CORS) and to
# be OAuth return destinations. Required when the frontend is hosted
# elsewhere — e.g. your GitHub Pages site:
ALLOWED_ORIGINS=https://shrlak.github.io

# Protect the dashboard with a master-password login. The app has no auth of
# its own, so set a password before exposing it on a public URL — anyone with
# the URL can otherwise read your inboxes/calendars. Leave unset for local/LAN
# use (the login is then disabled). Login establishes a signed session cookie
# that works even when the frontend and backend are on different origins.
# DASHBOARD_PASSWORD=
# Optional: secret used to sign session cookies. Defaults to DASHBOARD_PASSWORD.
# Set a long random value so changing the password isn't the only way to
# invalidate existing sessions. Changing it logs everyone out.
# SESSION_SECRET=

# Google OAuth client (Web application) from console.cloud.google.com.
# Enables the Gmail + Google Calendar integrations. Authorized redirect URI:
#   <origin>/api/auth/google/callback  (e.g. http://localhost:5173/api/auth/google/callback)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# iCloud calendars: make each calendar public in iCloud Calendar settings and
# paste the webcal:// share links here, comma-separated.
# ICLOUD_ICS_URLS=

# Override the default Google News RSS feeds, comma-separated URLs.
# NEWS_FEEDS_KO=
# NEWS_FEEDS_EN=

# Where OAuth tokens are stored (defaults to server/.data/).
# DATA_DIR=/data
